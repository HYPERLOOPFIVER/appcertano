    "icons": {
      "library": "Lucide React Native",
      "style": "Stroke width 2, rounded caps",
      "active_color": "#F50057",
      "inactive_color": "#9CA3AF"
    }
  },
  "animation_guidelines": {
    "library": "Moti",
    "transitions": {
      "page_load": {
        "from": { "opacity": 0, "translateY": 20 },
        "animate": { "opacity": 1, "translateY": 0 },
        "transition": { "type": "timing", "duration": 500 }
      },
      "modal_slide": {
        "from": { "translateY": 300, "opacity": 0 },
        "animate": { "translateY": 0, "opacity": 1 },
        "transition": { "type": "spring", "damping": 15 }
      },
      "button_press": {
        "scale": 0.96
      }
    }
  },
  "instructions_to_main_agent": [
    "REBUILD STRATEGY: Start with the Navigation (Tabs) and Header, then move to Feed, then Detail screens.",
    "COLOR USAGE: Use the Primary Pink (#F50057) sparingly for CTAs and active states. Do not overuse it.",
    "GRADIENTS: Use the 'Brand Gradient' for the Create Button and Story Rings only.",
    "ROUNDNESS: Everything should feel organic. Use high border-radius (20px+).",
    "MODALS: Replace standard RN Modals with 'Bottom Sheet' style animated views using Moti.",
    "DATA-TESTID: Ensure every TouchableOpacity and TextInput has a unique testID.",
    "PERFORMANCE: Use FlatList for feeds. Optimize images using cache policies if possible.",
    "ICONS: Use Lucide Icons. Import from 'lucide-react-native'.",
    "HEADER: Custom Header component. Do not use default Expo Router header if possible, or style it heavily to match.",
    "SPLASH: Use the 'backgrounds' image with a pulsing logo animation."
  ],
  "UNIVERSAL_GUIDELINES_FOR_MAIN_AGENT": [
    "Do not use gradients for dark colors.",
    "Avoid generic centered layouts. Use asymmetry.",
    "Create depth with shadows and z-index.",
    "Use 2-3x more spacing than typical.",
    "Every interaction needs micro-animations (Moti).",
    "All interactive elements MUST include data-testid."
  ]
}